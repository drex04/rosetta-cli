@prefix rose:  <http://rosetta.interop/ns/> .
@prefix qudt:  <http://qudt.org/schema/qudt/> .
@prefix unit:  <http://qudt.org/vocab/unit/> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .

# ─────────────────────────────────────────────────────────────────────────────
# Concepts
# ─────────────────────────────────────────────────────────────────────────────

rose:AirTrack
    a skos:Concept ;
    rdfs:label       "Air Track"@en ;
    rdfs:comment     "A correlated air contact maintained by a tracking system."@en ;
    skos:prefLabel   "Air Track"@en ;
    rose:hasAttribute
        rose:attr_Altitude_MSL ,
        rose:attr_Altitude_AGL ,
        rose:attr_Heading ,
        rose:attr_Speed ,
        rose:attr_Range ,
        rose:attr_Bearing ,
        rose:attr_Latitude ,
        rose:attr_Longitude ,
        rose:attr_Timestamp ,
        rose:attr_Track_ID ,
        rose:attr_Classification ,
        rose:attr_Track_Quality ,
        rose:attr_IFF_Code .

rose:RadarReturn
    a skos:Concept ;
    rdfs:label       "Radar Return"@en ;
    rdfs:comment     "Raw radar echo data associated with a detected target."@en ;
    skos:prefLabel   "Radar Return"@en ;
    rose:hasAttribute
        rose:attr_Signal_Strength ,
        rose:attr_Cross_Section ,
        rose:attr_Doppler_Shift .

rose:EngagementZone
    a skos:Concept ;
    rdfs:label       "Engagement Zone"@en ;
    rdfs:comment     "The three-dimensional region within which a weapon system can engage targets."@en ;
    skos:prefLabel   "Engagement Zone"@en ;
    rose:hasAttribute
        rose:attr_Min_Range ,
        rose:attr_Max_Range ,
        rose:attr_Min_Altitude ,
        rose:attr_Max_Altitude .

# ─────────────────────────────────────────────────────────────────────────────
# AirTrack attributes
# ─────────────────────────────────────────────────────────────────────────────

rose:attr_Altitude_MSL
    a rose:Attribute ;
    rdfs:label   "Altitude MSL"@en ;
    rdfs:comment "Altitude above mean sea level."@en ;
    qudt:unit    unit:M .

rose:attr_Altitude_AGL
    a rose:Attribute ;
    rdfs:label   "Altitude AGL"@en ;
    rdfs:comment "Altitude above ground level."@en ;
    qudt:unit    unit:M .

rose:attr_Heading
    a rose:Attribute ;
    rdfs:label   "Heading"@en ;
    rdfs:comment "Magnetic or true heading of the track in degrees."@en ;
    qudt:unit    unit:DEG .

rose:attr_Speed
    a rose:Attribute ;
    rdfs:label   "Speed"@en ;
    rdfs:comment "Ground speed of the track."@en ;
    qudt:unit    unit:KiloM-PER-HR .

rose:attr_Range
    a rose:Attribute ;
    rdfs:label   "Range"@en ;
    rdfs:comment "Slant range from the reporting sensor to the track."@en ;
    qudt:unit    unit:KiloM .

rose:attr_Bearing
    a rose:Attribute ;
    rdfs:label   "Bearing"@en ;
    rdfs:comment "Azimuth bearing from the reporting sensor to the track."@en ;
    qudt:unit    unit:DEG .

rose:attr_Latitude
    a rose:Attribute ;
    rdfs:label   "Latitude"@en ;
    rdfs:comment "WGS-84 geodetic latitude of the track position."@en ;
    qudt:unit    unit:DEG .

rose:attr_Longitude
    a rose:Attribute ;
    rdfs:label   "Longitude"@en ;
    rdfs:comment "WGS-84 geodetic longitude of the track position."@en ;
    qudt:unit    unit:DEG .

rose:attr_Timestamp
    a rose:Attribute ;
    rdfs:label   "Timestamp"@en ;
    rdfs:comment "UTC time of the track observation in ISO 8601 format."@en ;
    qudt:unit    unit:SEC .

rose:attr_Track_ID
    a rose:Attribute ;
    rdfs:label   "Track ID"@en ;
    rdfs:comment "Unique alphanumeric identifier assigned to the track."@en .

rose:attr_Classification
    a rose:Attribute ;
    rdfs:label   "Classification"@en ;
    rdfs:comment "Identification friend-or-foe classification: FRIEND, HOSTILE, UNKNOWN, SUSPECT, NEUTRAL."@en .

rose:attr_Track_Quality
    a rose:Attribute ;
    rdfs:label   "Track Quality"@en ;
    rdfs:comment "Numerical quality indicator (0–15) reflecting data confidence for the track."@en .

rose:attr_IFF_Code
    a rose:Attribute ;
    rdfs:label   "IFF Code"@en ;
    rdfs:comment "Identification Friend or Foe transponder mode and code."@en .

# ─────────────────────────────────────────────────────────────────────────────
# RadarReturn attributes
# ─────────────────────────────────────────────────────────────────────────────

rose:attr_Signal_Strength
    a rose:Attribute ;
    rdfs:label   "Signal Strength"@en ;
    rdfs:comment "Received signal power of the radar return."@en ;
    qudt:unit    unit:DBM .

rose:attr_Cross_Section
    a rose:Attribute ;
    rdfs:label   "Radar Cross Section"@en ;
    rdfs:comment "Effective radar cross section of the detected object in square metres."@en ;
    qudt:unit    unit:M2 .

rose:attr_Doppler_Shift
    a rose:Attribute ;
    rdfs:label   "Doppler Shift"@en ;
    rdfs:comment "Frequency shift due to radial velocity of the target, expressed in Hz."@en ;
    qudt:unit    unit:HZ .

# ─────────────────────────────────────────────────────────────────────────────
# EngagementZone attributes
# ─────────────────────────────────────────────────────────────────────────────

rose:attr_Min_Range
    a rose:Attribute ;
    rdfs:label   "Minimum Range"@en ;
    rdfs:comment "Minimum engagement range of the weapon system."@en ;
    qudt:unit    unit:KiloM .

rose:attr_Max_Range
    a rose:Attribute ;
    rdfs:label   "Maximum Range"@en ;
    rdfs:comment "Maximum engagement range of the weapon system."@en ;
    qudt:unit    unit:KiloM .

rose:attr_Min_Altitude
    a rose:Attribute ;
    rdfs:label   "Minimum Altitude"@en ;
    rdfs:comment "Minimum engagement altitude above MSL."@en ;
    qudt:unit    unit:M .

rose:attr_Max_Altitude
    a rose:Attribute ;
    rdfs:label   "Maximum Altitude"@en ;
    rdfs:comment "Maximum engagement altitude above MSL."@en ;
    qudt:unit    unit:M .

@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix mc: <https://ontology.nato.int/core/MasterCOP#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix unit: <http://qudt.org/vocab/unit/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

mc:ADIZ a sh:NodeShape ;
    rdfs:comment "Designated airspace in which identification, location, and control of civil and military aircraft is required in the interest of national security." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type prov:wasGeneratedBy prov:wasAttributedTo dcterms:created dcterms:source ) ;
    sh:property [ sh:datatype xsd:double ;
            sh:description "WGS-84 geodetic latitude in decimal degrees. Positive = north." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path mc:hasLatitude ],
        [ sh:datatype xsd:dateTime ;
            sh:description "UTC timestamp of the last update to this entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path mc:hasTimestamp ],
        [ sh:hasValue unit:DEG ;
            sh:path qudt:hasUnit ],
        [ sh:datatype xsd:double ;
            sh:description "WGS-84 geodetic longitude in decimal degrees. Positive = east." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path mc:hasLongitude ],
        [ sh:datatype xsd:string ;
            sh:description "The tactical callsign assigned to a unit or aircraft." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path mc:hasCallsign ],
        [ sh:hasValue unit:FT ;
            sh:path qudt:hasUnit ],
        [ sh:hasValue unit:DEG ;
            sh:path qudt:hasUnit ],
        [ sh:datatype xsd:double ;
            sh:description "Altitude above mean sea level in meters." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path mc:hasAltitude ],
        [ sh:datatype xsd:double ;
            sh:description "Altitude above mean sea level in feet." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path mc:hasAltitudeFt ],
        [ sh:datatype xsd:string ;
            sh:description "The originating system or data link that produced this entity (e.g., LINK16, LINK11, MIDS, JREAP-C)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path mc:hasSource ] ;
    sh:targetClass mc:ADIZ .

mc:ADSBReport a sh:NodeShape ;
    rdfs:comment "An Automatic Dependent Surveillance-Broadcast message from a civil or military aircraft." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type prov:wasGeneratedBy prov:wasAttributedTo dcterms:created dcterms:source ) ;
    sh:targetClass mc:ADSBReport .

mc:AEWPlatform a sh:NodeShape ;
    rdfs:comment "Airborne Early Warning platform (e.g., E-3 Sentry, E-2 Hawkeye) providing airborne surveillance and C2 relay." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type prov:wasGeneratedBy prov:wasAttributedTo dcterms:created dcterms:source ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The originating system or data link that produced this entity (e.g., LINK16, LINK11, MIDS, JREAP-C)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path mc:hasSource ],
        [ sh:hasValue unit:DEG ;
            sh:path qudt:hasUnit ],
        [ sh:hasValue unit:DEG ;
            sh:path qudt:hasUnit ],
        [ sh:datatype xsd:double ;
            sh:description "Altitude above mean sea level in feet." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path mc:hasAltitudeFt ],
        [ sh:hasValue unit:FT ;
            sh:path qudt:hasUnit ],
        [ sh:datatype xsd:string ;
            sh:description "The tactical callsign assigned to a unit or aircraft." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path mc:hasCallsign ],
        [ sh:datatype xsd:double ;
            sh:description "Altitude above mean sea level in meters." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path mc:hasAltitude ],
        [ sh:class mc:Unit ;
            sh:description "The unit that operates this platform." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path mc:operatedBy ],
        [ sh:datatype xsd:double ;
            sh:description "WGS-84 geodetic latitude in decimal degrees. Positive = north." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path mc:hasLatitude ],
        [ sh:datatype xsd:double ;
            sh:description "WGS-84 geodetic longitude in decimal degrees. Positive = east." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path mc:hasLongitude ],
        [ sh:datatype xsd:dateTime ;
            sh:description "UTC timestamp of the last update to this entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path mc:hasTimestamp ] ;
    sh:targetClass mc:AEWPlatform .

mc:AEWUnit a sh:NodeShape ;
    rdfs:comment "An airborne early warning unit providing extended radar coverage and airborne C2." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type prov:wasGeneratedBy prov:wasAttributedTo dcterms:created dcterms:source ) ;
    sh:property [ sh:hasValue unit:DEG ;
            sh:path qudt:hasUnit ],
        [ sh:datatype xsd:double ;
            sh:description "WGS-84 geodetic latitude in decimal degrees. Positive = north." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path mc:hasLatitude ],
        [ sh:datatype xsd:double ;
            sh:description "WGS-84 geodetic longitude in decimal degrees. Positive = east." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path mc:hasLongitude ],
        [ sh:datatype xsd:double ;
            sh:description "Altitude above mean sea level in meters." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path mc:hasAltitude ],
        [ sh:datatype xsd:string ;
            sh:description "The tactical callsign assigned to a unit or aircraft." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path mc:hasCallsign ],
        [ sh:datatype xsd:double ;
            sh:description "Altitude above mean sea level in feet." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path mc:hasAltitudeFt ],
        [ sh:hasValue unit:FT ;
            sh:path qudt:hasUnit ],
        [ sh:class mc:Zone ;
            sh:description "The airspace zone(s) for which this unit has air defense responsibility." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path mc:responsibleFor ],
        [ sh:datatype xsd:dateTime ;
            sh:description "UTC timestamp of the last update to this entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path mc:hasTimestamp ],
        [ sh:hasValue unit:DEG ;
            sh:path qudt:hasUnit ],
        [ sh:datatype xsd:string ;
            sh:description "The originating system or data link that produced this entity (e.g., LINK16, LINK11, MIDS, JREAP-C)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path mc:hasSource ] ;
    sh:targetClass mc:AEWUnit .

mc:AISReport a sh:NodeShape ;
    rdfs:comment "An Automatic Identification System broadcast from a maritime vessel." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type prov:wasGeneratedBy prov:wasAttributedTo dcterms:created dcterms:source ) ;
    sh:targetClass mc:AISReport .

mc:AirDefenseUnit a sh:NodeShape ;
    rdfs:comment "A unit whose primary mission is defense against air threats including missiles, aircraft, and UAS." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type prov:wasGeneratedBy prov:wasAttributedTo dcterms:created dcterms:source ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The originating system or data link that produced this entity (e.g., LINK16, LINK11, MIDS, JREAP-C)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path mc:hasSource ],
        [ sh:datatype xsd:string ;
            sh:description "The tactical callsign assigned to a unit or aircraft." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path mc:hasCallsign ],
        [ sh:hasValue unit:FT ;
            sh:path qudt:hasUnit ],
        [ sh:datatype xsd:double ;
            sh:description "WGS-84 geodetic latitude in decimal degrees. Positive = north." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path mc:hasLatitude ],
        [ sh:class mc:Zone ;
            sh:description "The airspace zone(s) for which this unit has air defense responsibility." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path mc:responsibleFor ],
        [ sh:datatype xsd:double ;
            sh:description "Altitude above mean sea level in meters." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path mc:hasAltitude ],
        [ sh:datatype xsd:double ;
            sh:description "WGS-84 geodetic longitude in decimal degrees. Positive = east." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path mc:hasLongitude ],
        [ sh:datatype xsd:double ;
            sh:description "Altitude above mean sea level in feet." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path mc:hasAltitudeFt ],
        [ sh:datatype xsd:dateTime ;
            sh:description "UTC timestamp of the last update to this entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path mc:hasTimestamp ],
        [ sh:hasValue unit:DEG ;
            sh:path qudt:hasUnit ],
        [ sh:hasValue unit:DEG ;
            sh:path qudt:hasUnit ] ;
    sh:targetClass mc:AirDefenseUnit .

mc:AirToAirMissile a sh:NodeShape ;
    rdfs:comment "A missile fired from an airborne platform at an airborne target." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type prov:wasGeneratedBy prov:wasAttributedTo dcterms:created dcterms:source ) ;
    sh:property [ sh:datatype xsd:double ;
            sh:description "WGS-84 geodetic longitude in decimal degrees. Positive = east." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path mc:hasLongitude ],
        [ sh:datatype xsd:double ;
            sh:description "Altitude above mean sea level in meters." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path mc:hasAltitude ],
        [ sh:datatype xsd:double ;
            sh:description "WGS-84 geodetic latitude in decimal degrees. Positive = north." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path mc:hasLatitude ],
        [ sh:hasValue unit:DEG ;
            sh:path qudt:hasUnit ],
        [ sh:hasValue unit:DEG ;
            sh:path qudt:hasUnit ],
        [ sh:datatype xsd:double ;
            sh:description "Altitude above mean sea level in feet." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path mc:hasAltitudeFt ],
        [ sh:hasValue unit:FT ;
            sh:path qudt:hasUnit ],
        [ sh:datatype xsd:string ;
            sh:description "The originating system or data link that produced this entity (e.g., LINK16, LINK11, MIDS, JREAP-C)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path mc:hasSource ],
        [ sh:datatype xsd:string ;
            sh:description "The tactical callsign assigned to a unit or aircraft." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path mc:hasCallsign ],
        [ sh:datatype xsd:string ;
            sh:description "NATO Stock Number (NSN) identifying the weapon type in the NATO supply catalogue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path mc:hasNATOStockNumber ],
        [ sh:datatype xsd:dateTime ;
            sh:description "UTC timestamp of the last update to this entity." ;
            sh:maxCount 1 ;

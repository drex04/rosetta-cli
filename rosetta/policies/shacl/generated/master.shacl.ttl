            sh:order 0 ;
            sh:path mc:operatedBy ] ;
    sh:targetClass mc:Aircraft .

mc:BallisticTrack a sh:NodeShape ;
    rdfs:comment "A track following a ballistic trajectory — typically a ballistic missile or large-calibre artillery round." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type prov:wasGeneratedBy prov:wasAttributedTo dcterms:created dcterms:source ) ;
    sh:property [ sh:class mc:Zone ;
            sh:description "The airspace zone(s) the track currently occupies." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path mc:withinZone ],
        [ sh:datatype xsd:string ;
            sh:description "IFF Mode 1 (mission type) code, two-digit octal string." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path mc:hasMode1Code ],
        [ sh:datatype xsd:double ;
            sh:description "Rate of climb or descent in feet per minute. Positive = climbing, negative = descending." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path mc:hasVerticalRate ],
        [ sh:hasValue unit:FT ;
            sh:path qudt:hasUnit ],
        [ sh:datatype xsd:double ;
            sh:description "Bearing from the reporting sensor to the track in degrees true." ;
            sh:maxCount 1 ;

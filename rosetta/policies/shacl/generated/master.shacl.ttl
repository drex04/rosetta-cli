mc:AirTrack a sh:NodeShape ;
    rdfs:comment "An airborne track — fixed-wing aircraft, rotary-wing aircraft, UAV, or missile in flight." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type prov:wasGeneratedBy prov:wasAttributedTo dcterms:created dcterms:source ) ;
    sh:property [ sh:datatype xsd:double ;
            sh:description "Fusion engine confidence score for this track (0.0–1.0)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path mc:hasConfidence ],
        [ sh:datatype xsd:string ;
            sh:description "IFF Mode 2 (unit identification) code, four-digit octal string." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path mc:hasMode2Code ],
        [ sh:class mc:IdentityCode ;
            sh:description "The tactical identity assigned to a track: FRIEND, HOSTILE, NEUTRAL, UNKNOWN, ASSUMED_FRIEND, PENDING, or SUSPECT." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path mc:hasIdentity ],
        [ sh:datatype xsd:string ;
            sh:description "Tactical track number assigned by the originating C2 system (e.g., H001, A042)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path mc:hasTrackNumber ],
        [ sh:hasValue unit:KN ;
            sh:path qudt:hasUnit ],
        [ sh:datatype xsd:double ;
            sh:description "Rate of climb or descent in feet per minute. Positive = climbing, negative = descending." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path mc:hasVerticalRate ],
        [ sh:class mc:EngagementStatus ;
            sh:description "Current engagement status of the track." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path mc:hasEngagementStatus ],
        [ sh:datatype xsd:integer ;
            sh:description "Track quality score (0–15) indicating sensor fusion confidence in the track solution." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path mc:hasTrackQuality ],
        [ sh:datatype xsd:string ;
            sh:description "IFF Mode 1 (mission type) code, two-digit octal string." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path mc:hasMode1Code ],
        [ sh:datatype xsd:double ;
            sh:description "Slant range from the reporting sensor to the track in nautical miles." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path mc:hasRange ],
        [ sh:class mc:ThreatLevel ;
            sh:description "Assessed threat level of the track: LOW, MEDIUM, HIGH, or CRITICAL." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path mc:hasThreatLevel ],
        [ sh:class mc:Platform ;
            sh:description "The sensor platform(s) that have contributed reports to this track." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path mc:detectedBy ],
        [ sh:datatype xsd:boolean ;
            sh:description "Whether a valid Mode 5 cryptographic IFF reply has been received for this track." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path mc:hasMode5 ],
        [ sh:hasValue unit:NauticalMile ;
            sh:path qudt:hasUnit ],
        [ sh:class mc:Unit ;
            sh:description "The C2 unit currently responsible for managing this track in the COP." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path mc:managedBy ],
        [ sh:hasValue unit:DEG ;
            sh:path qudt:hasUnit ],
        [ sh:datatype xsd:dateTime ;
            sh:description "UTC timestamp of the last update to this entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path mc:hasTimestamp ],
        [ sh:datatype xsd:string ;
            sh:description "The tactical callsign assigned to a unit or aircraft." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path mc:hasCallsign ],
        [ sh:datatype xsd:double ;
            sh:description "Track speed over ground in knots." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path mc:hasSpeed ],
        [ sh:class mc:Track ;
            sh:description "Another track that the fusion engine has associated as the same physical object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path mc:correlatedWith ],
        [ sh:hasValue unit:FT-PER-MIN ;
            sh:path qudt:hasUnit ],
        [ sh:class mc:Weapon ;
            sh:description "The weapon round assigned to intercept this track." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path mc:assignedWeapon ],
        [ sh:datatype xsd:double ;
            sh:description "WGS-84 geodetic latitude in decimal degrees. Positive = north." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 27 ;
            sh:path mc:hasLatitude ],
        [ sh:datatype xsd:string ;
            sh:description "IFF Mode 3/A (civil/military squawk) code, four-digit octal string." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path mc:hasMode3Code ],
        [ sh:datatype xsd:double ;
            sh:description "Bearing from the reporting sensor to the track in degrees true." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path mc:hasBearing ],
        [ sh:datatype xsd:double ;
            sh:description "Altitude above mean sea level in feet." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path mc:hasAltitudeFt ],
        [ sh:class mc:Zone ;
            sh:description "The airspace zone(s) the track currently occupies." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path mc:withinZone ],
        [ sh:datatype xsd:string ;
            sh:description "The originating system or data link that produced this entity (e.g., LINK16, LINK11, MIDS, JREAP-C)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path mc:hasSource ],
        [ sh:hasValue unit:DEG ;
            sh:path qudt:hasUnit ],
        [ sh:class mc:Unit ;
            sh:description "The fire unit currently assigned to engage this track." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path mc:engagedBy ],
        [ sh:hasValue unit:DEG ;
            sh:path qudt:hasUnit ],
        [ sh:hasValue unit:FT ;
            sh:path qudt:hasUnit ],
        [ sh:datatype xsd:double ;
            sh:description "Altitude above mean sea level in meters." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path mc:hasAltitude ],
        [ sh:class mc:SensorReport ;
            sh:description "The raw sensor reports fused to produce or update this track." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path mc:reportedBy ],
        [ sh:datatype xsd:double ;
            sh:description "WGS-84 geodetic longitude in decimal degrees. Positive = east." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path mc:hasLongitude ],
        [ sh:datatype xsd:double ;
            sh:description "Track heading in degrees true (0–360)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path mc:hasHeading ],
        [ sh:datatype xsd:string ;
            sh:description "Assessed platform type of the track (e.g., FIGHTER, BOMBER, HELICOPTER, MISSILE, UAS)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path mc:hasPlatformType ] ;
    sh:targetClass mc:AirTrack .

mc:Aircraft a sh:NodeShape ;
    rdfs:comment "An airborne platform — fighter, bomber, AWACS, tanker, transport, helicopter, or UAV." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type prov:wasGeneratedBy prov:wasAttributedTo dcterms:created dcterms:source ) ;

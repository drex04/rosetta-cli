<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           xmlns:tns="https://w3id.org/rosetta/stress/tracks"
           xmlns:common="https://w3id.org/rosetta/stress/common"
           targetNamespace="https://w3id.org/rosetta/stress/tracks"
           elementFormDefault="qualified">

  <!-- Imported namespace declaration — schemaLocation omitted because
       schema-automator's XSD importer does not resolve external imports.
       The `common:` prefix is kept as a grep marker for the two-namespace
       requirement. -->

  <xs:complexType name="TrackBase">
    <xs:sequence>
      <xs:element name="trackId" type="xs:string"/>
      <xs:element name="reportedAt" type="xs:dateTime"/>
    </xs:sequence>
    <xs:attribute name="source" type="xs:string" use="required"/>
    <xs:attribute name="classification" type="xs:string"/>
  </xs:complexType>

  <xs:complexType name="RadarTrack">
    <xs:complexContent>
      <xs:extension base="tns:TrackBase">
        <xs:sequence>
          <xs:element name="freqMhz" type="xs:decimal"/>
          <xs:choice>
            <xs:element name="emitter" type="xs:string"/>
            <xs:element name="receiver" type="xs:string"/>
          </xs:choice>
        </xs:sequence>
        <xs:attribute name="bandCode" type="xs:string"/>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:element name="radarTrack" type="tns:RadarTrack"/>

</xs:schema>
